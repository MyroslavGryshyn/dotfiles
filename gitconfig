[user]
	email = yvhn.yvhn@gmail.com
	name = yevhen-m
[core]
	excludesfile = ~/dotfiles/gitignore_global
[push]
	; Push only the current branch to the one that git pull will pull from
	; (check that their names match)
	default = simple
[diff]
	tool = vimdiff
[difftool]
	prompt = false
[alias]
	ss = status -s
	daddy = ! git show-branch -a 2>/dev/null | grep '\\*' | grep -v `git rev-parse --abbrev-ref HEAD` | head -n1 | sed 's/.*\\[\\(.*\\)\\].*/\\1/' | sed 's/[\\^~].*//'
	stash-unapply = !git stash show -p | git apply -R
[merge]
	tool = vimdiff
	conflictstyle = diff3
[color]
	ui = auto
[color "branch"]
	current = blue
	local = yellow
	remote = green
[color "diff"]
	meta = blue
	frag = magenta
	old = red
	new = green
[color "status"]
	added = yellow
	changed = green
	untracked = red
[pull]
	rebase = true
[fetch]
	prune = true
[mergetool]
	prompt = false
[clean]
	requireForce = false
