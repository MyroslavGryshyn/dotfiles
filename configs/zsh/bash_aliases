# MM Dagster aliases
alias dagster-run='cd ~/Dev/MM && PYTHONPATH=$PWD DAGSTER_HOME=~/.dagster dagster dev &'
alias dagster-start='dagster-run'
alias dagster-status='pgrep -fl dagster || echo "Dagster not running"'
alias dagster-stop='pkill -f "dagster dev"'
alias dagster-logs='tail -f ~/.dagster/dagster.log 2>/dev/null || echo "No logs yet"'
alias dagster-ui='open http://127.0.0.1:3000'

# Master Mind CLI
mm() {
    case "$1" in
        run|start)
            cd ~/Dev/MM && PYTHONPATH=$PWD DAGSTER_HOME=~/.dagster dagster dev
            ;;
        status)
            pgrep -fl dagster && echo "\nDagster UI: http://127.0.0.1:3000" || echo "Dagster not running"
            ;;
        stop)
            pkill -f "dagster dev" && echo "Dagster stopped"
            ;;
        logs)
            tail -f ~/.dagster/logs/*.log 2>/dev/null || echo "No logs"
            ;;
        ui)
            open http://127.0.0.1:3000
            ;;
        search)
            shift
            cd ~/Dev/MM && PYTHONPATH=$PWD python -m embeddings.search "$@"
            ;;
        *)
            echo "Usage: mm {run|start|status|stop|logs|ui|search}"
            ;;
    esac
}
