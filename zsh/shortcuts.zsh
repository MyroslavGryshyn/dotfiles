alias l='ls -1F --group-directories-first --color'
alias ll='k -hA --no-vcs'
alias la='ls -A --color'

# Linux shortcuts
alias pbcopy='xclip -sel clip'
alias pbpaste='xclip -sel clip -o'

# Git
alias gs='git status -sb'
alias gd='git diff -w'
alias gdc='git diff --cached -w'
alias gp='git push origin HEAD'

alias rm=trash
alias vim="nvim"
alias e="nvim"
