alias l='ls -1F --group-directories-first'
alias ll='ls -AFlh'
alias la='ls -A'

# Linux shortcuts
alias pbcopy='xclip -sel clip'
alias pbpaste='xclip -sel clip -o'

# Git
alias gs='git status -sb'
alias gd='git diff -w'
alias gdc='git diff --cached -w'
alias gl="git log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n''          %C(white)%s%C(reset) %C(bold blue)- %an%C(reset)' --all"

alias rm=trash
alias vim="nvim"
